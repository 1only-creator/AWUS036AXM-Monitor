<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1a1a2e">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AWUS036AXM Monitor Mode"
        android:textColor="#e94560"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Status indicator -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Idle"
        android:textColor="#ff4444"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"/>

    <!-- Channel selector -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Channel:"
        android:textColor="#cccccc"
        android:textSize="13sp"/>

    <Spinner
        android:id="@+id/spinnerChannel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#16213e"
        android:layout_marginBottom="16dp"/>

    <!-- Start / Stop -->
    <Button
        android:id="@+id/btnStartStop"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="START"
        android:backgroundTint="#e94560"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Usage hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connect in Termux:\nnc 127.0.0.1 37008 | tcpdump -r -\n\nOr in Wireshark:\nnc 127.0.0.1 37008 | wireshark -k -i -"
        android:textColor="#888888"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:background="#16213e"
        android:padding="8dp"
        android:layout_marginBottom="12dp"/>

    <!-- Log output -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0f3460">
        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00ff88"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"/>
    </ScrollView>

</LinearLayout>
